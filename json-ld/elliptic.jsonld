  },
  "@type": "Organization",
  "@id": "https://www.elliptic.co",
  "name": "Elliptic",
  "description": "Elliptic is a blockchain analytics and crypto compliance platform providing REST APIs for transaction screening, wallet risk scoring, entity identification, and AML compliance.",
  "url": "https://www.elliptic.co",
  "sameAs": [
    "https://developers.elliptic.co/",
    "https://app.elliptic.co"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "support",
    "url": "https://help.elliptic.co/"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Elliptic APIs",
    "itemListElement": [
      {
        "@type": "WebAPI",
        "name": "Elliptic AML API (OAuth)",
        "description": "REST API for automated AML compliance screening of cryptocurrency transactions and wallets with OAuth 2.0 authentication.",
        "version": "2.0.0",
        "documentation": "https://developers.elliptic.co/docs/aml-api-introduction",
        "url": "https://aml-api.elliptic.co",
        "termsOfService": "https://www.elliptic.co/terms-of-service",
